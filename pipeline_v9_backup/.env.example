# Copy this file to .env (same folder) and fill in your real key.
# NEVER commit .env and NEVER paste the key into any chat.
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
# Set to the exact model id shown in your DeepSeek platform/docs:
DEEPSEEK_MODEL=deepseek-chat

# --- scale-out (optional) ---
# Multiple API keys, comma-separated: LLM stages fan out across them
# round-robin (N keys = N parallel rate-limit budgets). See SCALABILITY.md.
# DEEPSEEK_API_KEYS=sk-key-one,sk-key-two,sk-key-three
# Parallel workers for M2/M3 map stages. 0 or unset = one worker per key.
# CLAUSE_WORKERS=0
